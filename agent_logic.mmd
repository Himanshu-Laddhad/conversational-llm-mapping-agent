%%{init: {"theme": "default", "flowchart": {"curve": "basis"}}}%%
flowchart TD

    %% ── INPUT LAYER ───────────────────────────────────────────────────────
    U([User / Streamlit UI]) -->|"Natural language message\n+ optional file upload(s)"| AUTH

    AUTH{{"Login Gate\napp.py"}}
    AUTH -->|Authenticated| SESSION

    %% ── SESSION LAYER ─────────────────────────────────────────────────────
    SESSION["Session Object\nsession.py\n─────────────\n• session_id  prefix\n• ingested_files list\n• xslt_indices dict\n• chat_history list\n• get_primary_ingested(msg)"]

    SESSION -->|"Ingested file(s)\n+ xslt_index\n+ chat history"| DISPATCH

    %% ── FILE INGESTION ────────────────────────────────────────────────────
    U2([File Upload]) -->|"Binary file bytes"| INGEST
    INGEST["file_ingestion.py\n─────────────\ndetect_file_type()\n  ├─ X12 EDI flat-file\n  ├─ EDIFACT\n  ├─ D365_XML\n  ├─ X12_XML  (MapForce)\n  ├─ XSLT / XSL\n  ├─ XSD\n  └─ Generic XML\n\nparse_*()\n→ structured dict"]
    INGEST --> SESSION

    %% ── XSLT INDEX (built at upload for XSLT files only) ─────────────────
    INGEST -->|"If file_type == XSLT"| XIDX
    XIDX["xslt_index.py\n─────────────\nbuild_xslt_index(ingested)\n  • templates dict\n  • variables dict\n  • segment_map dict\n  • raw_xml string\n\nTools for LLM:\n  search_xslt(keyword)\n  get_template(name)\n  get_variable(name)\n  get_segment_templates(seg)\n  get_call_chain(entry)"]
    XIDX -->|"session.set_xslt_index()"| SESSION

    %% ── RAG AUTO-CONTEXT ──────────────────────────────────────────────────
    RAG_Q["rag_engine.py\n─────────────\nquery_folder(msg)\n→ top-k relevant\n  snippets from\n  data/ index\n  (ChromaDB +\n   sentence-transformers)\n\nSkipped silently if\n.rag_index/ absent"]
    DISPATCH -->|"Always runs first\n(non-fatal if missing)"| RAG_Q
    RAG_Q -->|ctx_prefix string| DISPATCH

    %% ── DISPATCHER ────────────────────────────────────────────────────────
    DISPATCH["dispatcher.py\n─────────────\ndispatch(user_message,\n         file_paths,\n         session,\n         api_key)"]

    DISPATCH --> ROUTER

    %% ── INTENT ROUTER ─────────────────────────────────────────────────────
    ROUTER["intent_router.py\n─────────────\nGroq LLM zero-shot\nclassifier\nllama-3.1-8b-instant\n(877 tok/s, $0.05/M)\n\nFallback to OpenAI\nif no GROQ_API_KEY"]

    ROUTER -->|explain| ENG_EXP
    ROUTER -->|simulate| ENG_SIM
    ROUTER -->|modify| ENG_MOD
    ROUTER -->|generate| ENG_GEN
    ROUTER -->|audit| ENG_AUD
    ROUTER -->|folder| ENG_RAG

    %% ── ENGINES ───────────────────────────────────────────────────────────
    ENG_EXP["groq_agent.py\nExplain Engine\n─────────────\nIf xslt_index present:\n  Tool-calling loop\n  (OpenAI gpt-4.1-mini)\n  LLM explores index\n  via tool calls\n\nFallback:\n  Single-context\n  Groq chat\n→ prose explanation"]

    ENG_SIM["simulation_engine.py\nSimulate Engine\n─────────────\nSaxon-HE (XSLT 2.0/3.0)\n  → real XML output\n\nlxml (XSLT 1.0 fallback)\n  → real XML output\n\nLLM fallback\n  → predicted output\n(OpenAI gpt-4.1-mini)"]

    ENG_MOD["modification_engine.py\nModify Engine\n─────────────\nPrimary: tool-calling\n(OpenAI gpt-4.1)\n  1. LLM explores via tools\n  2. submit_patches once\n  3. apply bottom-to-top\n     _replace_at_line_hint()\n  4. verify_patches_applied()\n  5. validate well-formed\n  → (slim response + diff,\n     patched_xslt)\n\nFallback: legacy single\nBEFORE/AFTER patch"]

    ENG_GEN["xslt_generator.py\nGenerate Engine\n─────────────\nOpenAI gpt-4.1\nBuilds XSLT 2.0\nskeleton from NL spec\n→ (response_str,\n   generated_xslt)"]

    ENG_AUD["audit_engine.py\nAudit Engine\n─────────────\nLayer 1: Hardcoded rules\n  (NULL_CHECK, IF_NO_ELSE,\n   HARDCODED_IDS, ...)\nLayer 2: OpenAI gpt-4.1\n  dynamic analysis\n→ (prose_report,\n   questions_json)"]

    ENG_RAG["rag_engine.py\nFolder Query Engine\n─────────────\nindex_folder() + query_folder()\nAnswers cross-file questions\nacross all files in data/"]

    %% ── AUTO-AUDIT ────────────────────────────────────────────────────────
    ENG_MOD -->|"patched_xslt"| AUTO_AUDIT
    ENG_GEN -->|"generated_xslt"| AUTO_AUDIT
    AUTO_AUDIT["Auto-Audit\nRuns audit() on\nnewly generated\nor modified XSLT\n(OpenAI gpt-4.1)"]
    AUTO_AUDIT --> ENG_AUD

    %% ── AUDIT FORM LOOP ───────────────────────────────────────────────────
    ENG_AUD -->|questions_json| FORM
    FORM["Streamlit Form\napp.py\n─────────────\nRender question\nchecklist from JSON\nUser fills answers"]
    FORM -->|"answers dict"| FOLLOWUP
    FOLLOWUP["audit_followup()\n─────────────\nSecond-pass OpenAI\nverification with\nuser answers\n→ SAFE / REVIEW /\n  DO NOT DEPLOY verdict"]

    %% ── RESPONSE ASSEMBLY ─────────────────────────────────────────────────
    ENG_EXP --> RESULT
    ENG_SIM --> RESULT
    ENG_MOD --> RESULT
    ENG_GEN --> RESULT
    ENG_AUD --> RESULT
    ENG_RAG --> RESULT
    FOLLOWUP --> RESULT

    RESULT["dispatch() return dict\n─────────────\nprimary_response  string\nintent            string\npatched_xslt      string|None\naudit_report      string|None\naudit_questions   list|None\nrag_context_used  bool"]

    RESULT --> UI_RENDER

    %% ── UI RENDERING ──────────────────────────────────────────────────────
    UI_RENDER["app.py — Chat Bubble\n─────────────\n• Intent badge  (colour coded)\n• Assistant response text\n• Unified diff  (if modify)\n• Audit form  (if questions)\n• Download button  (if patched XSLT)\n• RAG sources badge"]

    UI_RENDER --> U

    %% ── RAG INDEX BUILD (offline) ─────────────────────────────────────────
    IDX["scripts/index_data.py\nOffline indexer\n─────────────\nWalk data/**\nChunk text\nEmbed (sentence-transformers)\nUpsert ChromaDB\n→ .rag_index/"]
    IDX -.->|"Populates index\n(run once)"| RAG_Q

    %% ── STYLES ────────────────────────────────────────────────────────────
    classDef engine  fill:#dbeafe,stroke:#2563eb,color:#1e3a5f
    classDef store   fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef io      fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef ui      fill:#f3e8ff,stroke:#7c3aed,color:#3b0764
    classDef router  fill:#ffe4e6,stroke:#e11d48,color:#881337
    classDef index   fill:#ecfdf5,stroke:#059669,color:#065f46

    class ENG_EXP,ENG_SIM,ENG_MOD,ENG_GEN,ENG_AUD,ENG_RAG,FOLLOWUP,AUTO_AUDIT engine
    class IDX,RAG_Q store
    class INGEST,SESSION io
    class AUTH,UI_RENDER,FORM,U,U2 ui
    class DISPATCH,ROUTER router
    class XIDX index
