# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API ──────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Intent Router config ──────────────────────────────────────────────────────
# LLM model to use for intent scoring
# Options: llama-3.3-70b-versatile | llama3-8b-8192 | mixtral-8x7b-32768
INTENT_ROUTER_MODEL=llama-3.3-70b-versatile

# Minimum confidence score (0.0–1.0) for an intent to be considered "active"
# Lower = more intents flagged | Higher = stricter detection
# Recommended range: 0.35 – 0.60
INTENT_ROUTER_THRESHOLD=0.45
