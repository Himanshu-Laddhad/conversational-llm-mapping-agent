# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
#   Windows / macOS / Linux:  cp .env.example .env
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── API Keys ──────────────────────────────────────────────────────────────────
# Only providers with a key set here will appear in the sidebar dropdown.

# OpenAI (PRIMARY — powers the XSLT tool-calling explain/modify path)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq (fallback — uses truncated-JSON explain path on free tier)
# https://console.groq.com/keys
GROQ_API_KEY=

# NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=

# Anthropic — https://console.anthropic.com/  (legacy path; no tool calling)
ANTHROPIC_API_KEY=

# ── Provider-level model defaults ────────────────────────────────────────────
# Fallback used when no per-engine override is set below.

OPENAI_MODEL=gpt-4.1-mini
GROQ_MODEL=llama-3.3-70b-versatile
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Per-engine model overrides ────────────────────────────────────────────────
# Each setting targets one specific task.  Takes priority over OPENAI_MODEL etc.
#
# Task          | Model                    | Provider  | Why
# --------------|--------------------------|-----------|--------------------------------
# explain       | gpt-4.1-mini             | OpenAI    | 1 M ctx, strong tool-calling
# modify        | gpt-4.1                  | OpenAI    | best diff/code editing
# simulate      | gpt-4.1-mini             | OpenAI    | code reasoning, cheaper
# audit         | gpt-4.1                  | OpenAI    | thorough structured analysis
# generate      | gpt-4.1                  | OpenAI    | top code-gen (SWE-bench 54.6%)
# intent router | llama-3.1-8b-instant     | Groq      | 877 tok/s, $0.05/M, classification

EXPLAIN_MODEL=gpt-4.1-mini
MODIFY_MODEL=gpt-4.1
SIMULATE_MODEL=gpt-4.1-mini
AUDIT_MODEL=gpt-4.1
GENERATE_MODEL=gpt-4.1

# Intent routing always uses Groq for speed + cost (GROQ_API_KEY required).
# Falls back to the active OpenAI provider if no Groq key is set.
INTENT_ROUTER_MODEL=llama-3.1-8b-instant
INTENT_ROUTER_THRESHOLD=0.45

# ── Login gate ────────────────────────────────────────────────────────────────
# Override the default demo password. Set a strong value in production.
# DEMO_PASSWORD=partnerlinq2026

# ── HuggingFace offline mode ──────────────────────────────────────────────────
# Prevents sentence-transformers from reaching huggingface.co on startup.
# The all-MiniLM-L6-v2 model is already cached locally.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
