# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your keys
#   Windows / macOS / Linux:  cp .env.example .env
# DO NOT commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM providers (set the keys for whichever providers you use) ────────────
# The Streamlit sidebar can override these at runtime; these env vars pre-fill
# the UI and work for CLI / scripts when no key is typed in the app.

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# NVIDIA NIM — https://build.nvidia.com/ (API key for integrate.api.nvidia.com)
NVIDIA_API_KEY=

# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Optional: override default model for all engines (any provider) ─────────
# If unset, each provider uses its built-in default (see modules/llm_client.py).
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Intent Router ───────────────────────────────────────────────────────────
# LLM model id for intent scoring (must match the provider you select in the UI)
INTENT_ROUTER_MODEL=llama-3.3-70b-versatile

# Minimum confidence (0.0–1.0) for an intent to be "active"
INTENT_ROUTER_THRESHOLD=0.45

# ── Login gate (demo / internal use) ────────────────────────────────────────
# Override the default demo password. Set a strong password in production.
# DEMO_PASSWORD=partnerlinq2026
