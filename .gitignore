# ══════════════════════════════════════════════════════════════════════════════
# INDUSTRY PRACTICUM - PARTNERLINQ
# .gitignore — Files that should NOT be tracked by Git
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit API keys, credentials, or sensitive config
.env
.env.local
.env.*.local
*.env
!.env.example
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
config.json
secrets.json

# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
pyvenv.cfg

# ── Python ────────────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.dll
*.dylib

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
*.manifest
*.spec

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
htmlcov/
nosetests.xml
.cache

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py
*.ipynb

# ── IDEs & Editors ────────────────────────────────────────────────────────────
# VSCode
.vscode/
.vscode-test/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
.elc
auto-save-list
tramp

# ── Logs & Temporary Files ────────────────────────────────────────────────────
*.log
*.log.*
logs/
log/
temp/
tmp/
*.tmp
*.temp
*.bak
*.backup
*.cache

# ── OS Files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# ── Database Files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── Documentation ─────────────────────────────────────────────────────────────
docs/_build/
docs/_static/
docs/_templates/
site/
.doctrees/
*.pdf
*.epub

# ── Type Checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Project-Specific ──────────────────────────────────────────────────────────
# Sample/test data files (uncomment if you want to exclude them)
# test_data/
# samples/
# *.x12
# *.edi
# *.edifact
# *.xml
# *.xsl
# *.xslt

# Output/processed files
output/
processed/
results/

# Large model files (if using local LLM models)
*.bin
*.gguf
*.safetensors
models/

# Backup files
*_backup.*
*_old.*

# ── Package Managers ──────────────────────────────────────────────────────────
# pip
pip-wheel-metadata/
.Python

# Poetry
poetry.lock

# Pipenv
Pipfile.lock

# Conda
.conda/

# ── CI/CD ─────────────────────────────────────────────────────────────────────
.github/workflows/*.log
.gitlab-ci-local/

# ── Other ─────────────────────────────────────────────────────────────────────
.DS_STORE
*.rdb
celerybeat-schedule
celerybeat.pid

# ── MappingData ────────────────────────────────────────────────────────────────
# Large sample/test data folder — kept locally but not tracked by git.
# OneDrive holds file locks on these folders which breaks git checkout.
MappingData/

# ── data/ — user mapping files ─────────────────────────────────────────────────
# Drop your XSLT / XML / XSD / EDI files here and run scripts/index_data.py.
# Contents are never committed (files may be large or proprietary).
# The folder itself (.gitkeep) IS committed so it exists after git clone.
data/*
!data/.gitkeep

# ── RAG vector index ───────────────────────────────────────────────────────────
# Built locally by scripts/index_data.py — never committed.
# Each machine builds its own index; re-run the script after adding new files.
.rag_index/