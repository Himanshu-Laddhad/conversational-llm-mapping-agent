# ══════════════════════════════════════════════════════════════════════════════
# .gitignore — Do not track secrets, local/runtime state, or machine-specific files
# (safe defaults for sharing the repo with clients or publishing)
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit API keys, credentials, or sensitive config
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
*.env
!.env.example
.envrc
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
config.json
secrets.json
*credentials*.json
*secret*.json
!**/.secrets.baseline
google-*-credentials*.json
firebase-adminsdk*.json
**/serviceAccount*.json
**/serviceAccountKey*.json
.aws/
.azure/
.msazure/

# Internal / one-off presentations (add negated patterns if you need a deck in-repo)
*.pptx

# ── IDE & local tool metadata (do not ship to clients) ──────────────────────
.cursor/
**/.cursor/
.agent/

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
pyvenv.cfg

# ── Python ────────────────────────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.dll
*.dylib

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# PyInstaller
*.manifest
*.spec

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
.hypothesis/
htmlcov/
nosetests.xml
.cache

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py
*.ipynb

# ── IDEs & Editors ────────────────────────────────────────────────────────────
# VSCode
.vscode/
.vscode-test/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
.elc
auto-save-list
tramp

# ── Logs & Temporary Files ────────────────────────────────────────────────────
*.log
*.log.*
logs/
log/
temp/
tmp/
*.tmp
*.temp
*.bak
*.backup
*.cache

# ── OS Files ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
~$*

# Linux
*~
.directory
.Trash-*

# ── Database Files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# ── Documentation ─────────────────────────────────────────────────────────────
docs/_build/
docs/_static/
docs/_templates/
site/
.doctrees/
*.pdf
*.epub

# ── Type Checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# ── Samples, fixtures, and local inputs (do not ship to clients) ─────────────
test/*
!test/.gitkeep
test_data/
samples/
sample_data/
fixtures/
example_data/
**/sample_inputs/

# ── Generated outputs & exports ───────────────────────────────────────────────
output/
outputs/
out/
processed/
results/
exports/
generated/
scratch/
runs/
artifacts/
reports/

# Large model files (if using local LLM models)
*.bin
*.gguf
*.safetensors
models/

# Backup files
*_backup.*
*_old.*

# ── Package Managers ──────────────────────────────────────────────────────────
# pip
pip-wheel-metadata/
.Python

# Poetry
poetry.lock

# Pipenv
Pipfile.lock

# Conda
.conda/

# ── CI/CD ─────────────────────────────────────────────────────────────────────
.github/workflows/*.log
.gitlab-ci-local/

# ── Other ─────────────────────────────────────────────────────────────────────
.DS_STORE
*.rdb
celerybeat-schedule
celerybeat.pid

# ── MappingData ────────────────────────────────────────────────────────────────
# Large sample/test data folder — kept locally but not tracked by git.
# OneDrive holds file locks on these folders which breaks git checkout.
MappingData/

# ── data/ — user mapping files ─────────────────────────────────────────────────
# Drop your XSLT / XML / XSD / EDI files here and run scripts/index_data.py.
# Contents are never committed (files may be large or proprietary).
# The folder itself (.gitkeep) IS committed so it exists after git clone.
data/*
!data/.gitkeep

# ── RAG vector index ───────────────────────────────────────────────────────────
# Built locally by scripts/index_data.py — never committed.
# Each machine builds its own index; re-run the script after adding new files.
.rag_index/

# ── Local SQLite stores ───────────────────────────────────────────────────────
# Created at runtime; never committed.
rules_store.db
rules_store.db-*

# ── Runtime-generated XSLT artefacts ─────────────────────────────────────────
# Temp files written by the dispatcher for simulate / modify / generate flows.
# Downloaded by the user via the UI; should not be tracked.
data/uploads/
*_patched.xml
*_generated.xml
*_latest_revision.xml
# Ad-hoc output from modification_engine when run from repo root
patched.xml

# Referenced by modules for local samples; often proprietary — keep out of client repos
test_files/

# HuggingFace / sentence-transformers caches if created under project root
.cache/
