%% PartnerLinQ — Conversational Mapping Intelligence Agent
%% High-level system architecture with request lifecycle sub-diagram

flowchart TB

    %% ── SYSTEM OVERVIEW ────────────────────────────────────────────────────

    subgraph USER["USER & INTERFACE"]
        U[["👤 User\nBusiness or IT stakeholder"]]
        UI[["🖥️ Streamlit UI\napp.py\nChat, multi-file upload,\noutput panel, audit form,\ndownload button"]]
    end

    subgraph PARTNERLINQ["PARTNERLINQ DATA"]
        PD[["📁 Partner Data\ndata/ — XSLT, XML, XSD,\nEDI, D365 XML mappings\n(git-ignored)"]]
        RAG[["🔍 .rag_index/\nChromaDB vector store\nBuilt via scripts/index_data.py\n(optional — graceful skip if absent)"]]
    end

    subgraph INGESTION["FILE INGESTION"]
        FI[["📥 file_ingestion.py\nDetects & parses:\n X12 EDI · EDIFACT\n D365_XML · X12_XML\n XSLT · XSD · XML"]]
        XIDX[["🗂️ xslt_index.py\nIn-memory XSLT index\nbuilt at upload time\n(templates, variables,\n segment_map, raw_xml)\n\nExposes 5 tool functions\nfor LLM exploration"]]
    end

    subgraph CORE["CORE ROUTING"]
        IR[["🧭 intent_router.py\nGroq llama-3.1-8b-instant\nClassifies: explain,\nsimulate, modify,\ngenerate, audit, folder\n\nFallback → OpenAI\nif no GROQ_API_KEY"]]
        SESS[["💾 session.py\nConversation memory\ningested_files list\nxslt_indices dict\nturn history"]]
        CB[["🧩 Context Builder\ndispatcher.py\nSession history +\nRAG snippets +\nxslt_index ref"]]
        DISP[["⚙️ dispatcher.py\nCentral orchestration hub\nResolves per-engine models\nfrom env vars"]]
    end

    subgraph CAPABILITY["CAPABILITY ENGINES"]
        EXP[["📋 Explain\ngroq_agent.py\nTool-calling explore +\nOpenAI gpt-4.1-mini\nor legacy single-context"]]
        SIM[["▶️ Simulate\nsimulation_engine.py\nSaxon-HE → lxml →\nLLM cascade\n(gpt-4.1-mini)"]]
        MOD[["✏️ Modify\nmodification_engine.py\nTool-calling multi-patch\n(gpt-4.1)\n• submit_patches tool\n• _replace_at_line_hint\n• verify + diff output"]]
        GEN[["🔧 Generate\nxslt_generator.py\nCreate XSLT from spec\n(gpt-4.1)"]]
        AUD[["✅ Audit\naudit_engine.py\nRules layer +\nOpenAI gpt-4.1\n→ SAFE / REVIEW /\n  DO NOT DEPLOY"]]
        FRAG[["🔍 Folder Query\nrag_engine.py\nCross-file knowledge base\nqueries (ChromaDB)"]]
    end

    subgraph GOVERNANCE["GOVERNANCE & VERIFICATION"]
        AUDV[["📋 Audit Verification\naudit_followup()\nStructured Q&A form\n→ final verdict"]]
        RS[["🗃️ rules_store.py\nSQLite audit log\napproved versions\nevent history"]]
    end

    subgraph MODELS["LLM PROVIDERS"]
        GROQ[["⚡ Groq\nllama-3.1-8b-instant\nIntent classification only\n877 tok/s · $0.05/M"]]
        OAI[["🤖 OpenAI\ngpt-4.1-mini — explain, simulate\ngpt-4.1 — modify, audit, generate\n1M token context · tool calling"]]
    end

    %% ── CONNECTIONS ────────────────────────────────────────────────────────

    U --> UI
    UI -->|"user message, file_paths"| IR
    UI -->|"uploaded files"| FI

    PD --> FI
    PD -->|"index source"| RAG
    RAG -->|"query_folder"| CB

    FI -->|"ingested dict"| SESS
    FI -->|"if XSLT"| XIDX
    XIDX -->|"xslt_index"| SESS

    SESS --> CB
    CB -->|"context prefix"| DISP
    IR -->|"active_intents"| DISP
    FI -->|"ingested"| DISP
    SESS -->|"get_primary_ingested\nget_xslt_index"| DISP

    DISP --> EXP
    DISP --> SIM
    DISP --> MOD
    DISP --> GEN
    DISP --> AUD
    DISP --> FRAG

    EXP -->|"tool calls"| XIDX
    MOD -->|"tool calls\n(search, get_template\nget_call_chain)"| XIDX

    MOD -.->|"auto-audit patched_xslt"| AUD
    GEN -.->|"auto-audit generated_xslt"| AUD

    AUD --> AUDV
    AUD --> RS

    DISP --> SESS
    DISP --> RS

    EXP --> UI
    SIM --> UI
    MOD --> UI
    GEN --> UI
    AUD --> UI
    FRAG --> UI
    AUDV -->|"verdict"| UI

    IR -->|"classification call"| GROQ
    EXP -->|"tool-calling loop"| OAI
    MOD -->|"tool-calling loop"| OAI
    SIM -->|"LLM fallback"| OAI
    GEN -->|"generation"| OAI
    AUD -->|"analysis"| OAI
    FRAG -->|"RAG answer"| GROQ

    %% ── REQUEST LIFECYCLE (right side inset) ───────────────────────────────

    subgraph LIFECYCLE["REQUEST LIFECYCLE"]
        direction LR
        L1[["1. User sends message"]]
        L2[["2. Ingest new files\n   Build xslt_index if XSLT"]]
        L3[["3. Build context\n   Session history +\n   RAG query_folder"]]
        L4[["4. Classify intent\n   Groq llama-3.1-8b"]]
        L5[["5. Dispatch to engine(s)\n   Engine-specific model\n   from env var"]]
        L6[["6. Apply patches / diff\n   verify + validate\n   Auto-audit if modify/gen"]]
        L7[["7. Render response\n   Badge · Text · Diff\n   Form · Download button"]]

        L1 --> L2 --> L3 --> L4 --> L5 --> L6 --> L7
    end

